POST .slo-observability.sli-v3*/_search
{
  "sort": [
    {
      "event.ingested": {
        "order": "desc"
      }
    }
  ],
  "query": {
    "bool": {
      "filter": [
        {
          "term": {
            "slo.id": "id"
          }
        },
        {
          "term": {
            "slo.instanceId": "instanceId"
          }
        }
      ]
    }
  }
}
